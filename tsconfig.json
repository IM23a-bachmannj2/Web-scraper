{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "target": "ES2021",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "module": "ES2022",
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": [
    "src/*"
  ]
}